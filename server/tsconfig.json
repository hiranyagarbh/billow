{
  "compilerOptions": {
    /* ── Output ─────────────────────────────────────────────── */
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",

    /* ── Strictness ─────────────────────────────────────────── */
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    /* ── Extra safety flags ─────────────────────────────────── */
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
