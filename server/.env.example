# Billow Server Configuration
PORT=4000
NODE_ENV=development

# Set to 'true' to use mock data (no AWS credentials needed)
USE_MOCK_DATA=true

# AWS Configuration (only needed when USE_MOCK_DATA=false)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# DynamoDB
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_TABLE_COSTS=BillowCosts
DYNAMODB_TABLE_BUDGET=BillowBudget

# CORS
CORS_ORIGIN=http://localhost:5173
