# ============================================
# Billow — Environment Configuration
# ============================================
# Copy this file to .env: cp .env.example .env

# Server
PORT=4000
NODE_ENV=development

# Mock Data Mode
# Set to 'true' to use generated mock data (no AWS credentials needed)
# Set to 'false' to use real AWS Cost Explorer data
USE_MOCK_DATA=true

# AWS Configuration (only needed when USE_MOCK_DATA=false)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# DynamoDB
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_TABLE_COSTS=BillowCosts
DYNAMODB_TABLE_BUDGET=BillowBudget

# CORS
CORS_ORIGIN=http://localhost:5173

# Frontend (used by Vite)
VITE_API_URL=http://localhost:4000
